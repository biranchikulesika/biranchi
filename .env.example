# ==============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# ==============================================================================
# This file serves as a reference for configuring the application.
# Copy this file to `.env` or `.env.local` and fill in the values for your environment.
# Note: Key variables must never be committed to repository control.

# ------------------------------------------------------------------------------
# 1. DATABASE / BACKEND SERVICE (SUPABASE INTEGRATION)
# ------------------------------------------------------------------------------

# NEXT_PUBLIC_USE_SUPABASE: Toggle the persistent PostgreSQL repository database.
# - Required: Optional (defaults to true if NEXT_PUBLIC_SUPABASE_URL is provided)
# - Scope: Universal (Client & Server)
# - Values: "true" | "false"
NEXT_PUBLIC_USE_SUPABASE="true"

# NEXT_PUBLIC_SUPABASE_URL: The public API URL of your Supabase project instance.
# - Required: Yes (when using persistent Supabase mode)
# - Scope: Universal (Client & Server)
# - Example: "https://abcdefghijklmopqrst.supabase.co"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"

# NEXT_PUBLIC_SUPABASE_ANON_KEY: The public anonymous API key for client-side queries.
# - Required: Yes (when using persistent Supabase mode)
# - Scope: Universal (Client & Server)
# - Example: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: Highly privileged secret key for server-side operations.
# - Required: Yes (enables admin panels to bypass RLS rules safely on the server side)
# - Scope: Server-side only (MUST KEEP SECRET)
# - Example: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ------------------------------------------------------------------------------
# 2. AUTOMATION & BACKGROUND JOBS
# ------------------------------------------------------------------------------

# CRON_SECRET: Secret key for verifying automated cron requests.
# - Required: Yes (for secure cron endpoints)
# - Scope: Server-side only
# - Example: "your-super-secret-cron-key"
CRON_SECRET=""

# GITHUB_TOKEN: GitHub Personal Access Token for fetching commit logs.
# - Required: Yes (for the build logs generation script)
# - Scope: Server-side only
# - Example: "ghp_xxxxxxxxxxxxxxxxxxxx"
GITHUB_TOKEN=""

# ------------------------------------------------------------------------------
# 3. AI INTEGRATION (BUILD LOGS)
# ------------------------------------------------------------------------------

# AI_PROVIDER: Which AI provider to use for summarizing logs.
# - Required: No (defaults to 'nvidia')
# - Values: "nvidia" | "openai"
AI_PROVIDER="nvidia"

# AI_API_KEY: The API key for your chosen AI provider.
# - Required: Yes (if generating AI logs)
# - Scope: Server-side only
AI_API_KEY=""

# AI_MODEL: The AI model to use for completion.
# - Required: No (defaults to 'deepseek-ai/deepseek-v4-flash')
AI_MODEL="deepseek-ai/deepseek-v4-flash"

# AI_BASE_URL: Custom base URL if using a custom provider.
# - Required: No
AI_BASE_URL=""

# (Optional specific provider keys, if not using generic AI_API_KEY)
NVIDIA_API_KEY=""
OPENAI_API_KEY=""

# ------------------------------------------------------------------------------
# 4. OPTIONAL VERCEL INTEGRATION / EXTRA DOMAIN VARIABLES
# ------------------------------------------------------------------------------

# NEXT_PUBLIC_ROOT_DOMAIN: Base domain of the application deployment if using custom domains.
# - Required: No
# - Scope: Universal (Client & Server)
# - Example: "yourdomain.com"
NEXT_PUBLIC_ROOT_DOMAIN=""

# NEXT_PUBLIC_USE_SUBDOMAINS: Enable multi-tenant subdomains routing.
# - Required: No (defaults to false)
# - Scope: Universal (Client & Server)
# - Values: "true" | "false"
NEXT_PUBLIC_USE_SUBDOMAINS="false"

# ------------------------------------------------------------------------------
# 5. PAYMENT GATEWAY (RAZORPAY INTEGRATION)
# ------------------------------------------------------------------------------

# NEXT_PUBLIC_RAZORPAY_KEY_ID: Public API Key ID for Razorpay Client
# - Required: Yes (for checkout)
# - Scope: Universal (Client & Server)
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# RAZORPAY_KEY_SECRET: Secret API Key for Razorpay Server
# - Required: Yes (for creating orders & verification)
# - Scope: Server-side only
RAZORPAY_KEY_SECRET=""

# RAZORPAY_WEBHOOK_SECRET: Secret signature for Webhook verification
# - Required: Yes (for webhooks)
# - Scope: Server-side only
RAZORPAY_WEBHOOK_SECRET=""
